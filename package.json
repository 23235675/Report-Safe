{
  "name": "report-safe",
  "version": "1.0.0",
  "private": true,
  "description": "Report Safe (報平安) — a resilient disaster-status reporting system.",
  "workspaces": [
    "server",
    "web",
    "mobile"
  ],
  "scripts": {
    "start": "node server/src/index.js",
    "dev:server": "cd server && node src/index.js",
    "dev:web": "cd web && npx vite",
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "build:web": "cd web && npx vite build",
    "test": "vitest run",
    "db:up": "cd server && npm run db:up",
    "db:down": "cd server && npm run db:down",
    "db:reset": "cd server && npm run db:reset"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-transform-private-methods": "^7.29.7",
    "@babel/plugin-transform-private-property-in-object": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~18.3.0",
    "concurrently": "^8.2.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "domexception": "^4.0.0",
    "vite": "8.0.16",
    "web-streams-polyfill": "^4.3.0"
  }
}
