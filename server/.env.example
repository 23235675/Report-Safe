# ============================================================================
# Report Safe Backend Configuration
# ============================================================================

# HTTP server port
PORT=3001

# Government/admin access token (privileged API auth).
# Simple value for local/testing; PRODUCTION: override with a strong random
# secret. The compare is timing-safe and the value is read only from here (never
# hardcoded), so the security mechanism is production-grade regardless of length.
GOV_TOKEN=12345678

# ── Super admin (provisioned at boot by db/seedAdmin.js) ────────────────────
# Credentials are read from these vars ONLY — never hardcoded in source. Simple
# values for testing; set strong ones in production (a <12-char password warns
# at boot when NODE_ENV=production). Login: POST /api/admin/login.
SUPER_ADMIN_PHONE=+85212345678
SUPER_ADMIN_PASSWORD=12345678
SUPER_ADMIN_NAME=Super Administrator

# ── OTP / phone verification (production-ready, OFF by default) ──────────────
# OFF keeps test account creation frictionless. Set OTP_ENABLED=true to require
# a verified one-time passcode on register/login (request it via
# POST /api/users/request-otp). In dev the code is logged and echoed in the
# response (dev_code) so no real phone/SMS gateway is needed; wire a real SMS
# provider in otpService.sendSms for production.
OTP_ENABLED=false
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ── HKID validation strictness ──────────────────────────────────────────────
# false (default) = lenient: any value with 1+ letter and 6+ digits passes, so
# testers can create accounts without a real ID. true = full HK mod-11 check-
# digit verification (the production rule; logic always present in zodSchemas).
HKID_STRICT=false

# ── User token lifecycle (production hardening) ─────────────────────────────
# Per-user access tokens now EXPIRE; clients refresh them via
# POST /api/users/token/refresh using the longer-lived refresh token.
# Access-token lifetime in hours (default 24).
ACCESS_TOKEN_TTL_HOURS=24
# Refresh-token lifetime in days (default 30). Rotated on every refresh.
REFRESH_TOKEN_TTL_DAYS=30

# Disaster trigger engine polling interval (milliseconds)
DISASTER_POLL_INTERVAL_MS=30000

# ── Remote push: Azure Notification Hubs (optional) ─────────────────────────
# Wakes CLOSED mobile apps with a native FCM/APNs disaster alert (the socket
# path only reaches running apps). Unset = graceful no-op (local notifications
# still work). The hub must be wired to your FCM v1 + APNs creds in the Azure
# portal. Connection string = the hub's "DefaultFullSharedAccessSignature".
# AZURE_NH_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;SharedAccessKey=<key>
# AZURE_NH_HUB_NAME=report-safe-hub

# ── Security / ops ──────────────────────────────────────────────────────────
# Comma-separated CORS allowlist ('*' for dev only).
CORS_ORIGIN=*
# Coarse API rate limit (requests/min/IP). Stricter limits apply to register/links.
RATE_LIMIT_PER_MIN=300
# Number of reverse-proxy hops in front of the app (for correct client IPs).
TRUST_PROXY_HOPS=1
# Send HSTS header (enable only when served over HTTPS).
ENABLE_HSTS=false
# Structured log level: error | warn | info | debug
LOG_LEVEL=info

# Demo-only rotating HK early-warning signals (default OFF — disasters come
# from the seed or POST /api/disasters/trigger; the app is DB-driven)
ENABLE_MOCK_FEEDS=false

# Number of random Hong Kong user accounts created on first seed
SEED_USER_COUNT=10000

# PDPO data retention (DPP2): auto-purge RESOLVED reports (safe/rescued/deceased)
# whose last update is older than N days. 0 or unset = disabled (retain forever).
RETENTION_DAYS=0

# WebSocket stats broadcast interval (milliseconds)
WS_STATS_INTERVAL_MS=10000

# ── Redis (optional — multi-instance scaling M3/R6) ─────────────────────────
# When any REDIS_* var is set the Socket.IO Redis adapter is attached (cross-
# instance events) and rate-limit counters are shared across all instances.
# Unset / empty = single-instance mode (default for local dev).
#
# Full URL form (takes priority over discrete vars):
# REDIS_URL=redis://localhost:6379
#
# Discrete form (docker-compose redis service listens on 6379):
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# ============================================================================
# MongoDB Configuration (Azure Cosmos DB for MongoDB)
# ============================================================================
# The app connects to a MongoDB-compatible database (Azure Cosmos DB for
# MongoDB in production: RU-based, serverless, API v7.0). Geo queries use a
# lat/lng bounding-box prefilter + JS haversine — no PostGIS required.

# Full connection string (preferred). For Cosmos: portal → your account →
# "Connection strings" → Primary Connection String. It already contains
# ssl=true&retrywrites=false (both REQUIRED for Cosmos RU-based).
#   - Cosmos: mongodb://<acct>:<key>@<acct>.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&appName=@<acct>@
#   - Local:  mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Database (collection namespace) name.
MONGODB_DB=reportsafe

# Connection pool size + connect timeout (ms). Cosmos serverless can cold-start.
MONGO_POOL_MAX=10
MONGO_CONN_TIMEOUT_MS=20000

# ============================================================================
# Local MongoDB (Development)
# ============================================================================
# Run a local MongoDB 7 container (matches Cosmos API v7.0):
#   docker run -d --name rs-mongo -p 27017:27017 mongo:7
# Then keep MONGODB_URI=mongodb://localhost:27017 (the default above).
