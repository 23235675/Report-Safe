{
  "name": "report-safe-server",
  "version": "1.0.0",
  "private": true,
  "description": "Report Safe backend — Express + Socket.IO + MongoDB (Azure Cosmos DB for MongoDB).",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:up": "docker compose -f ../docker-compose.yml up -d mongo",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:reset": "node src/db/reset.js",
    "db:generate": "node scripts/generateData.js"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^7.3.0",
    "redis": "^6.0.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
