# ============================================================================
# Report Safe — PRODUCTION environment (copy to .env.prod, never commit it)
# Used by docker-compose.prod.yml (server-1/server-2) and the Caddy proxy.
# ============================================================================

NODE_ENV=production
PORT=3001

# ── HTTPS / reverse proxy (Caddy) ───────────────────────────────────────────
# Your public domain + an email for Let's Encrypt registration.
DOMAIN=reportsafe.example.com
TLS_EMAIL=ops@example.com
# Behind Caddy there is exactly one proxy hop.
TRUST_PROXY_HOPS=1
# Caddy terminates TLS, so the app should emit HSTS too.
ENABLE_HSTS=true
# Lock CORS to your real origin(s) — comma-separated, NEVER '*' in production.
CORS_ORIGIN=https://reportsafe.example.com

# ── Secrets ─────────────────────────────────────────────────────────────────
# Generate a strong value, e.g.  openssl rand -base64 48
GOV_TOKEN=__CHANGE_ME__strong-random-secret
ACCESS_TOKEN_TTL_HOURS=24
REFRESH_TOKEN_TTL_DAYS=30

# ── Azure Cosmos DB for MongoDB (managed) ───────────────────────────────────
# Portal → your Cosmos account → "Connection strings" → Primary Connection
# String. It already includes ssl=true&retrywrites=false (both REQUIRED for
# Cosmos RU-based). MONGODB_DB is the database name you create in the account.
MONGODB_URI=mongodb://__ACCT__:__KEY__@__ACCT__.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000&appName=@__ACCT__@
MONGODB_DB=reportsafe
MONGO_POOL_MAX=20
MONGO_CONN_TIMEOUT_MS=20000

# ── Redis (cross-instance Socket.IO + rate limiting) ────────────────────────
# The compose file ships a redis service named "redis".
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Azure Notification Hubs (remote push) ───────────────────────────────────
AZURE_NH_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;SharedAccessKey=<key>
AZURE_NH_HUB_NAME=report-safe-hub

# ── PDPO data retention (DPP2) ──────────────────────────────────────────────
# Auto-purge RESOLVED reports (safe/rescued/deceased) older than N days.
# Set a real value in production (e.g. 90) — 0 keeps data forever.
RETENTION_DAYS=90

# ── Ops ─────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=600
LOG_LEVEL=info
ENABLE_MOCK_FEEDS=false
SEED_USER_COUNT=0
