# Firebase web config — copy to `mobile/.env` and fill in.
# Source: Firebase console → Project settings → "Your apps".
#
# NOTE: a Firebase Web API key is a project *identifier*, not a secret. The real
# protection is in Google Cloud Console: add Application restrictions (Android
# package name + SHA-1 / iOS bundle id) and API restrictions to this key.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_VAPID_KEY=
